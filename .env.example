# ------------------------------------------------------------------------------
# Required application settings
# ------------------------------------------------------------------------------

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fuckjournal?schema=public"
NEXTAUTH_URL="http://127.0.0.1:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:3000"

# Storage provider:
# - local: good for local development or disposable environments
# - vercel-blob: recommended for Vercel preview and production
STORAGE_PROVIDER="local"

# Notification provider:
# - mock: structured logging, recommended for local/preview and initial launch
# - disabled: suppress dispatch while keeping workflow logic active
NOTIFICATION_PROVIDER="mock"

# ------------------------------------------------------------------------------
# Optional rate limits and request sizing
# ------------------------------------------------------------------------------

AUTH_RATE_LIMIT_WINDOW_MS="900000"
AUTH_LOGIN_RATE_LIMIT_MAX="10"
AUTH_REGISTER_RATE_LIMIT_MAX="5"
UPLOAD_RATE_LIMIT_WINDOW_MS="900000"
UPLOAD_RATE_LIMIT_MAX="20"
MAX_AUTH_JSON_BYTES="16384"

# ------------------------------------------------------------------------------
# Optional file storage controls
# ------------------------------------------------------------------------------

LOCAL_STORAGE_DIR=".uploads"
MAX_MANUSCRIPT_PDF_BYTES="26214400"
ENABLE_PUBLICATION_DOWNLOADS=""

# Legacy/internal compatibility hook. The public author workflow is PDF-first,
# but this value remains available because storage and validation layers still
# expose compatibility surfaces that may be used in older records.
MAX_SOURCE_ARCHIVE_BYTES="52428800"

# Required only when STORAGE_PROVIDER=vercel-blob
BLOB_READ_WRITE_TOKEN=""

# Optional only for environments where Playwright cannot locate Chromium
# automatically. Not required for normal app startup.
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=""

# ------------------------------------------------------------------------------
# Local development and test seeding
# ------------------------------------------------------------------------------

SEED_TEST_USER_EMAIL="contributor@fuckjournal.local"
SEED_TEST_USER_PASSWORD="Phase1User123!"
SEED_TEST_REVIEWER_EMAIL="reviewer@fuckjournal.local"
SEED_TEST_REVIEWER_PASSWORD="Phase3Reviewer123!"
SEED_TEST_EDITOR_EMAIL="editor@fuckjournal.local"
SEED_TEST_EDITOR_PASSWORD="Phase1Editor123!"

# Optional admin seed account
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# ------------------------------------------------------------------------------
# Deployment notes
# ------------------------------------------------------------------------------

# Preview:
# - Set NEXTAUTH_URL and NEXT_PUBLIC_SITE_URL to the exact preview URL.
# - Keep NOTIFICATION_PROVIDER=mock unless you need a real provider.
#
# Production:
# - Set NEXTAUTH_URL and NEXT_PUBLIC_SITE_URL to the canonical production origin.
# - Prefer STORAGE_PROVIDER=vercel-blob on Vercel.
# - Run `npm run db:deploy` before or during release.
