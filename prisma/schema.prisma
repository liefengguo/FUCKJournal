generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  EDITOR
  ADMIN
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  ACCEPTED
  REJECTED
}

model User {
  id               String                  @id @default(cuid())
  name             String?
  email            String                  @unique
  passwordHash     String
  role             UserRole                @default(USER)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  submissions      Submission[]
  versionSnapshots SubmissionVersion[]
  statusEvents     SubmissionStatusEvent[]
}

model Submission {
  id                   String                  @id @default(cuid())
  publicId             String                  @unique
  authorId             String
  title                String                  @default("")
  abstract             String?                 @db.Text
  coverLetter          String?                 @db.Text
  manuscriptLanguage   String?
  manuscriptFileName   String?
  manuscriptStorageKey String?
  manuscriptMimeType   String?
  manuscriptSizeBytes  Int?
  status               SubmissionStatus        @default(DRAFT)
  submittedAt          DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  author               User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions             SubmissionVersion[]
  statusEvents         SubmissionStatusEvent[]

  @@index([authorId, status])
  @@index([status, updatedAt])
}

model SubmissionVersion {
  id                   String     @id @default(cuid())
  submissionId         String
  versionNumber        Int
  createdById          String
  title                String
  abstract             String?    @db.Text
  coverLetter          String?    @db.Text
  manuscriptLanguage   String?
  manuscriptFileName   String?
  manuscriptStorageKey String?
  manuscriptMimeType   String?
  manuscriptSizeBytes  Int?
  createdAt            DateTime   @default(now())
  submission           Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdBy            User       @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([submissionId, versionNumber])
  @@index([submissionId, createdAt])
}

model SubmissionStatusEvent {
  id           String            @id @default(cuid())
  submissionId String
  actorId      String
  fromStatus   SubmissionStatus?
  toStatus     SubmissionStatus
  note         String?           @db.Text
  createdAt    DateTime          @default(now())
  submission   Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  actor        User              @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
}
