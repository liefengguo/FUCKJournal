generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  REVIEWER
  EDITOR
  ADMIN
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  ACCEPTED
  REJECTED
}

enum ReviewerAssignmentStatus {
  ACTIVE
  COMPLETED
  REMOVED
}

enum ReviewDecision {
  ACCEPT
  MINOR_REVISION
  MAJOR_REVISION
  REJECT
}

model User {
  id                         String                  @id @default(cuid())
  name                       String?
  email                      String                  @unique
  passwordHash               String
  role                       UserRole                @default(USER)
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  submissions                Submission[]
  versionSnapshots           SubmissionVersion[]
  statusEvents               SubmissionStatusEvent[]
  internalNotes              InternalEditorNote[]
  reviewerAssignments        ReviewerAssignment[]    @relation("ReviewerAssignments")
  reviewerAssignmentsCreated ReviewerAssignment[]    @relation("ReviewerAssigner")
  reviews                    Review[]                @relation("ReviewerReviews")
}

model Submission {
  id                           String                  @id @default(cuid())
  publicId                     String                  @unique
  authorId                     String
  title                        String                  @default("")
  abstract                     String?                 @db.Text
  keywords                     String[]                @default([])
  coverLetter                  String?                 @db.Text
  introduction                 String?                 @db.Text
  mainContent                  String?                 @db.Text
  conclusion                   String?                 @db.Text
  references                   String?                 @db.Text
  manuscriptLanguage           String?
  manuscriptFileName           String?
  manuscriptStorageKey         String?
  manuscriptStorageProvider    String?
  manuscriptMimeType           String?
  manuscriptSizeBytes          Int?
  sourceArchiveFileName        String?
  sourceArchiveStorageKey      String?
  sourceArchiveStorageProvider String?
  sourceArchiveMimeType        String?
  sourceArchiveSizeBytes       Int?
  status                       SubmissionStatus        @default(DRAFT)
  isPublicationReady           Boolean                 @default(false)
  publicationSlug              String?                 @unique
  publicationTitle             String?
  publicationExcerpt           String?                 @db.Text
  publicationTags              String[]                @default([])
  publicationLocale            String?
  publicationVolume            String?
  publicationIssue             String?
  publicationYear              Int?
  seoTitle                     String?
  seoDescription               String?                 @db.Text
  publishedAt                  DateTime?
  submittedAt                  DateTime?
  createdAt                    DateTime                @default(now())
  updatedAt                    DateTime                @updatedAt
  author                       User                    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  versions                     SubmissionVersion[]
  statusEvents                 SubmissionStatusEvent[]
  internalNotes                InternalEditorNote[]
  reviewerAssignments          ReviewerAssignment[]
  reviews                      Review[]

  @@index([authorId, status])
  @@index([status, updatedAt])
  @@index([status, isPublicationReady, publishedAt])
  @@index([manuscriptLanguage])
  @@index([publicationLocale])
}

model SubmissionVersion {
  id                           String           @id @default(cuid())
  submissionId                 String
  versionNumber                Int
  createdById                  String
  label                        String
  statusContext                SubmissionStatus
  title                        String
  abstract                     String?          @db.Text
  keywords                     String[]         @default([])
  coverLetter                  String?          @db.Text
  introduction                 String?          @db.Text
  mainContent                  String?          @db.Text
  conclusion                   String?          @db.Text
  references                   String?          @db.Text
  manuscriptLanguage           String?
  manuscriptFileName           String?
  manuscriptStorageKey         String?
  manuscriptStorageProvider    String?
  manuscriptMimeType           String?
  manuscriptSizeBytes          Int?
  sourceArchiveFileName        String?
  sourceArchiveStorageKey      String?
  sourceArchiveStorageProvider String?
  sourceArchiveMimeType        String?
  sourceArchiveSizeBytes       Int?
  createdAt                    DateTime         @default(now())
  submission                   Submission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  createdBy                    User             @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([submissionId, versionNumber])
  @@index([submissionId, createdAt])
}

model SubmissionStatusEvent {
  id           String            @id @default(cuid())
  submissionId String
  actorId      String
  fromStatus   SubmissionStatus?
  toStatus     SubmissionStatus
  note         String?           @db.Text
  createdAt    DateTime          @default(now())
  submission   Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  actor        User              @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
}

model InternalEditorNote {
  id           String     @id @default(cuid())
  submissionId String
  authorId     String
  body         String     @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  author       User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
}

model ReviewerAssignment {
  id           String                   @id @default(cuid())
  submissionId String
  reviewerId   String
  assignedById String
  status       ReviewerAssignmentStatus @default(ACTIVE)
  invitedAt    DateTime                 @default(now())
  respondedAt  DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  submission   Submission               @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer     User                     @relation("ReviewerAssignments", fields: [reviewerId], references: [id], onDelete: Cascade)
  assignedBy   User                     @relation("ReviewerAssigner", fields: [assignedById], references: [id], onDelete: Cascade)
  review       Review?

  @@unique([submissionId, reviewerId])
  @@index([reviewerId, status, updatedAt])
  @@index([submissionId, status])
}

model Review {
  id                   String             @id @default(cuid())
  submissionId         String
  reviewerId           String
  reviewerAssignmentId String             @unique
  decision             ReviewDecision
  commentsToAuthor     String?            @db.Text
  commentsToEditor     String?            @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  submission           Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer             User               @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewerAssignment   ReviewerAssignment @relation(fields: [reviewerAssignmentId], references: [id], onDelete: Cascade)

  @@unique([submissionId, reviewerId])
  @@index([submissionId, updatedAt])
  @@index([reviewerId, updatedAt])
}
